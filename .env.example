PORT=4000
APP_NAME=Finance Tracker
CORS_ORIGIN=*

# Learning tab AI tutor (optional)
# Uses an OpenAI-compatible Chat Completions endpoint.
# Set either LLM_API_KEY or OPENAI_API_KEY.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=20000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/finance_tracker

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h

# Data encryption key used for stored provider credentials
APP_ENCRYPTION_KEY=replace-with-a-long-random-encryption-key

# Connector modes:
# - eq_bank: disabled, plaid, or eq_mobile_api
# - td, amex: disabled or plaid
# - wealthsimple: disabled, plaid, snaptrade, or manual_holdings
EQ_BANK_MODE=disabled
WEALTHSIMPLE_MODE=disabled
TD_MODE=disabled
AMEX_MODE=disabled

# EQ mobile API (required when EQ_BANK_MODE=eq_mobile_api)
# Docs source: https://github.com/bufutda/eq-bank-api/blob/master/API.md
EQ_BANK_API_BASE_URL=https://mobile-api.eqbank.ca/mobile/v1.1/
EQ_BANK_API_AUTHORIZATION=Basic NjdjZjI5Yjc3MmIwNGI3NGFiYTcxYmViOGQzOTljMjQ6N2VBMDUzNjczMjdjNDU2M0IwQzRiYkQ5MDkzQkFBZjU=
EQ_BANK_CLIENT_OS=android
EQ_BANK_CLIENT_VERSION=2.3.34
EQ_BANK_TRUST_DEVICE=true

# Plaid (required when any mode=plaid)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_COUNTRY_CODES=CA,US
PLAID_REDIRECT_URI=

# SnapTrade (required when WEALTHSIMPLE_MODE=snaptrade)
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_BASE_URL=https://api.snaptrade.com/api/v1

# Quotes (used by WEALTHSIMPLE_MODE=manual_holdings)
# QUOTE_PROVIDER: stooq, yahoo, none
QUOTE_PROVIDER=stooq
QUOTE_DEFAULT_SUFFIX=.TO
QUOTE_CDR_SUFFIX=.NE
QUOTE_TIMEOUT_MS=8000
QUOTE_MAX_CONCURRENCY=6

# Flight lookup (used by Misc -> Flight Logbook)
# Provider priority:
# 1) FlightAware AeroAPI (recommended)
#    - /flights endpoint for recent flights (about 10-day historical window)
#    - /schedules endpoint for historical aircraft/type lookups (about 3 months)
#    - If this key is set, lookup prefers FlightAware; when needed it can
#      fall back to ADSB route data enriched by FlightAware aircraft/delay.
#    Docs: https://www.flightaware.com/commercial/aeroapi/
FLIGHTAWARE_AEROAPI_KEY=
# Alias also supported: FLIGHTAWARE_API_KEY
# 2) Cirium FlightStats (optional fallback)
#    Docs: https://developer.flightstats.com/api-docs/flightstatus/v2
CIRIUM_APP_ID=
CIRIUM_APP_KEY=
# Legacy aliases also supported: FLIGHTSTATS_APP_ID / FLIGHTSTATS_APP_KEY

# 3) aviationstack (optional fallback)
AVIATIONSTACK_API_KEY=

# Background jobs (optional)
# Set to 60 to re-sync connections hourly in-process.
AUTO_SYNC_INTERVAL_MINUTES=0
