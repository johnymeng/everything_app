PORT=4000
APP_NAME=Finance Tracker
CORS_ORIGIN=*

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/finance_tracker

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h

# Data encryption key used for stored provider credentials
APP_ENCRYPTION_KEY=replace-with-a-long-random-encryption-key

# Connector modes:
# - eq_bank: mock, plaid, or eq_mobile_api
# - td, amex: mock or plaid
# - wealthsimple: mock, plaid, or snaptrade
EQ_BANK_MODE=eq_mobile_api
WEALTHSIMPLE_MODE=mock
TD_MODE=mock
AMEX_MODE=mock

# EQ mobile API (required when EQ_BANK_MODE=eq_mobile_api)
# Docs source: https://github.com/bufutda/eq-bank-api/blob/master/API.md
EQ_BANK_API_BASE_URL=https://mobile-api.eqbank.ca/mobile/v1.1/
EQ_BANK_API_AUTHORIZATION=Basic NjdjZjI5Yjc3MmIwNGI3NGFiYTcxYmViOGQzOTljMjQ6N2VBMDUzNjczMjdjNDU2M0IwQzRiYkQ5MDkzQkFBZjU=
EQ_BANK_CLIENT_OS=android
EQ_BANK_CLIENT_VERSION=2.3.34
EQ_BANK_TRUST_DEVICE=true

# Plaid (required when any mode=plaid)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_COUNTRY_CODES=CA,US
PLAID_REDIRECT_URI=

# SnapTrade (required when WEALTHSIMPLE_MODE=snaptrade)
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_BASE_URL=https://api.snaptrade.com/api/v1
